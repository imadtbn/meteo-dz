                    </div>
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-wind"></i></div>
                        <div class="stat-value" id="statWind">--km/h</div>
                        <div class="stat-label">متوسط سرعة الرياح</div>
                        <div class="stat-change down"><i class="fas fa-arrow-down"></i> -5%</div>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="temperatureChart"></canvas>
                </div>
            </div>
        </section>

        <!-- Weather Tips -->
        <section class="tips-section">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">نصائح طقسية</h2>
                </div>
                <div class="tips-grid" id="weatherTips">
                    <div class="tip-card">
                        <div class="tip-icon"><i class="fas fa-sun"></i></div>
                        <h3 class="tip-title">حماية من الشمس</h3>
                        <p class="tip-text">مؤشر الأشعة فوق البنفسجية مرتفع. استخدم واقي الشمس وارتدي نظارات شمسية وقبعة للحماية.</p>
                        <span class="tip-severity medium">تنبيه متوسط</span>
                    </div>
                    <div class="tip-card">
                        <div class="tip-icon"><i class="fas fa-tint"></i></div>
                        <h3 class="tip-title">ترطيب الجسم</h3>
                        <p class="tip-text">اشرب 8-10 أكواب من الماء يومياً خاصة مع ارتفاع درجات الحرارة لتجنب الجفاف.</p>
                        <span class="tip-severity low">نصيحة عامة</span>
                    </div>
                    <div class="tip-card">
                        <div class="tip-icon"><i class="fas fa-umbrella"></i></div>
                        <h3 class="tip-title">استعد للأمطار</h3>
                        <p class="tip-text">توقعات بهطول أمطار غداً. احمل مظلتك وتجنب القيادة في المناطق المنخفضة.</p>
                        <span class="tip-severity medium">تنبيه متوسط</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Warnings -->
        <section class="warnings-section" id="warnings">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">نشرات التحذير</h2>
                </div>
                <div class="warnings-grid" id="warningsGrid">
                    <div class="warning-card heat">
                        <div class="warning-header">
                            <div class="warning-icon heat"><i class="fas fa-temperature-high"></i></div>
                            <div>
                                <div class="warning-title">موجة حرارة</div>
                                <div class="warning-status">الجنوب الجزائري</div>
                            </div>
                        </div>
                        <p class="warning-text">توقعات بموجة حر شديدة في ولايات الجنوب مع درجات حرارة تتجاوز 45°C. تجنب التعرض المباشر للشمس.</p>
                        <div class="warning-meta">
                            <span class="warning-time"><i class="fas fa-clock"></i> منذ 2 ساعة</span>
                            <span class="warning-badge active">تحذير نشط</span>
                        </div>
                    </div>
                    <div class="warning-card wind">
                        <div class="warning-header">
                            <div class="warning-icon wind"><i class="fas fa-wind"></i></div>
                            <div>
                                <div class="warning-title">رياح قوية</div>
                                <div class="warning-status">السواحل الغربية</div>
                            </div>
                        </div>
                        <p class="warning-text">رياح قوية قد تصل سرعتها إلى 70 كم/س على السواحل الغربية. احذر من الأجسام الطائرة.</p>
                        <div class="warning-meta">
                            <span class="warning-time"><i class="fas fa-clock"></i> منذ 4 ساعات</span>
                            <span class="warning-badge watch">مراقبة</span>
                        </div>
                    </div>
                    <div class="warning-card sea">
                        <div class="warning-header">
                            <div class="warning-icon sea"><i class="fas fa-water"></i></div>
                            <div>
                                <div class="warning-title">بحر مضطرب</div>
                                <div class="warning-status">البحر المتوسط</div>
                            </div>
                        </div>
                        <p class="warning-text">ارتفاع الأمواج إلى 2.5 متر مع رياح شمالية غربية. غير مناسب للقوارب الصغيرة.</p>
                        <div class="warning-meta">
                            <span class="warning-time"><i class="fas fa-clock"></i> منذ 6 ساعات</span>
                            <span class="warning-badge active">تحذير نشط</span>
                        </div>
                    </div>
                    <div class="warning-card cold">
                        <div class="warning-header">
                            <div class="warning-icon cold"><i class="fas fa-snowflake"></i></div>
                            <div>
                                <div class="warning-title">موجة برد</div>
                                <div class="warning-status">الهضاب العليا</div>
                            </div>
                        </div>
                        <p class="warning-text">انخفاض درجات الحرارة في المناطق الجبلية ليلاً. ارتدِ ملابس دافئة واحذر من الانزلاق.</p>
                        <div class="warning-meta">
                            <span class="warning-time"><i class="fas fa-clock"></i> منذ 8 ساعات</span>
                            <span class="warning-badge safe">آمن</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

